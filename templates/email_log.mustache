{{!
    @template local_msgraph_api_mailer/email_log

    Email log viewer template for MS Graph API Mailer.

    @package    local_msgraph_api_mailer
    @copyright  2026 Krishna Gupta
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<div style="max-width:1140px; margin:0 auto;">

    {{! Filter card }}
    <div class="msgraph-card">
        <div class="msgraph-card-header">
            <i class="fa fa-filter text-primary"></i>
            <h4>{{#str}} log_filter_heading, local_msgraph_api_mailer {{/str}}</h4>
        </div>
        <div class="msgraph-card-body">
            <form method="get" action="">
                <div class="filter-row">

                    <div class="filter-group">
                        <label for="fl-status">
                            {{#str}} log_col_status, local_msgraph_api_mailer {{/str}}
                        </label>
                        <select id="fl-status" name="status"
                            class="form-control form-control-sm" style="min-width:110px;">
                            <option value="-1"
                                {{#filter_status_all_selected}}selected{{/filter_status_all_selected}}>
                                {{#str}} log_status_all, local_msgraph_api_mailer {{/str}}
                            </option>
                            <option value="1"
                                {{#filter_status_sent_selected}}selected{{/filter_status_sent_selected}}>
                                {{#str}} log_status_sent, local_msgraph_api_mailer {{/str}}
                            </option>
                            <option value="0"
                                {{#filter_status_failed_selected}}selected{{/filter_status_failed_selected}}>
                                {{#str}} log_status_failed, local_msgraph_api_mailer {{/str}}
                            </option>
                        </select>
                    </div>

                    <div class="filter-group">
                        <label for="fl-recipient">
                            {{#str}} log_col_recipient, local_msgraph_api_mailer {{/str}}
                        </label>
                        <input id="fl-recipient" type="text" name="recipient"
                            class="form-control form-control-sm"
                            placeholder="user@example.com" style="min-width:200px;"
                            value="{{filter_recipient}}">
                    </div>

                    <div class="filter-group">
                        <label for="fl-subject">
                            {{#str}} log_col_subject, local_msgraph_api_mailer {{/str}}
                        </label>
                        <input id="fl-subject" type="text" name="subject"
                            class="form-control form-control-sm"
                            placeholder="{{subject_placeholder}}" style="min-width:200px;"
                            value="{{filter_subject}}">
                    </div>

                    <div class="filter-group">
                        <label for="fl-datefrom">
                            {{#str}} log_filter_from, local_msgraph_api_mailer {{/str}}
                        </label>
                        <input id="fl-datefrom" type="date" name="datefrom"
                            class="form-control form-control-sm"
                            value="{{filter_datefrom}}">
                    </div>

                    <div class="filter-group">
                        <label for="fl-dateto">
                            {{#str}} log_filter_to, local_msgraph_api_mailer {{/str}}
                        </label>
                        <input id="fl-dateto" type="date" name="dateto"
                            class="form-control form-control-sm"
                            value="{{filter_dateto}}">
                    </div>

                    <div class="filter-group" style="flex-direction:row; gap:6px; padding-top:1px;">
                        <button type="submit" class="btn btn-primary btn-sm"
                            style="align-self:flex-end;">
                            <i class="fa fa-search"></i>
                            {{#str}} log_btn_filter, local_msgraph_api_mailer {{/str}}
                        </button>
                        <a href="?" class="btn btn-secondary btn-sm" style="align-self:flex-end;">
                            <i class="fa fa-times"></i>
                            {{#str}} log_btn_clear, local_msgraph_api_mailer {{/str}}
                        </a>
                    </div>

                </div>
            </form>
        </div>
    </div>

    {{! Log table card }}
    <div class="msgraph-card">
        <div class="msgraph-card-header" style="justify-content:space-between;">
            <div style="display:flex; align-items:center; gap:8px;">
                <i class="fa fa-list text-primary"></i>
                <h4>{{#str}} email_log_title, local_msgraph_api_mailer {{/str}}</h4>
            </div>
            <div style="display:flex; align-items:center; gap:10px;">
                <span class="badge bg-primary text-white"
                    style="font-size:.85rem; padding:5px 10px;">
                    {{total}} {{#str}} log_records_count, local_msgraph_api_mailer {{/str}}
                </span>
                <a href="{{export_url}}" class="btn btn-success btn-sm">
                    <i class="fa fa-download"></i>
                    {{#str}} log_btn_export, local_msgraph_api_mailer {{/str}}
                </a>
            </div>
        </div>

        <div style="padding:0;">
            {{^has_records}}
            <div class="p-4 text-center text-muted">
                <i class="fa fa-inbox fa-2x mb-2 d-block"></i>
                {{#str}} log_no_records, local_msgraph_api_mailer {{/str}}
            </div>
            {{/has_records}}

            {{#has_records}}
            <div class="table-responsive">
                <table class="table table-hover table-sm mb-0" style="font-size:.875rem;">
                    <thead class="table-light">
                        <tr>
                            <th style="width:55px; padding-left:16px;">ID</th>
                            <th>{{#str}} log_col_recipient, local_msgraph_api_mailer {{/str}}</th>
                            <th>{{#str}} log_col_subject, local_msgraph_api_mailer {{/str}}</th>
                            <th style="width:90px; text-align:center;">
                                {{#str}} log_col_status, local_msgraph_api_mailer {{/str}}
                            </th>
                            <th style="width:80px; text-align:center;">
                                {{#str}} log_col_attachment, local_msgraph_api_mailer {{/str}}
                            </th>
                            <th>{{#str}} log_col_response, local_msgraph_api_mailer {{/str}}</th>
                            <th style="width:155px;">
                                {{#str}} log_col_datetime, local_msgraph_api_mailer {{/str}}
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#records}}
                        <tr>
                            <td class="text-muted" style="padding-left:16px;">{{id}}</td>
                            <td>{{recipients}}</td>
                            <td>{{subject}}</td>
                            <td style="text-align:center;">
                                <span class="{{status_badge_class}}">{{status_label}}</span>
                            </td>
                            <td style="text-align:center;">
                                {{#has_attachment}}
                                <span title="Has attachment" style="color:#0078d4; font-size:1rem;">
                                    <i class="fa fa-paperclip"></i>
                                </span>
                                {{/has_attachment}}
                                {{^has_attachment}}
                                <span style="color:#adb5bd;">&mdash;</span>
                                {{/has_attachment}}
                            </td>
                            <td>
                                <div class="log-response" title="{{response}}">
                                    {{response}}
                                </div>
                            </td>
                            <td class="text-muted">{{timecreated}}</td>
                        </tr>
                        {{/records}}
                    </tbody>
                </table>
            </div>
            <div style="padding:12px 16px;">
                {{{paging_bar}}}
            </div>
            {{/has_records}}
        </div>
    </div>

    {{! Navigation }}
    <div class="mb-4" style="display:flex; gap:8px;">
        <a href="{{settings_url}}" class="btn btn-secondary">
            <i class="fa fa-arrow-left"></i>
            {{#str}} back_to_settings, local_msgraph_api_mailer {{/str}}
        </a>
        <a href="{{test_url}}" class="btn btn-outline-secondary">
            <i class="fa fa-flask"></i>
            {{#str}} test_validate, local_msgraph_api_mailer {{/str}}
        </a>
    </div>

</div>
